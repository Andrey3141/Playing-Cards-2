<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    tools:context=".MainActivity">

    <!-- Декоративные карточки на фоне -->
    <ImageView
        android:id="@+id/card1"
        android:layout_width="@dimen/card_width"
        android:layout_height="@dimen/card_height"
        android:src="@drawable/card_back"
        android:rotation="-15"
        android:alpha="0.2"
        android:translationX="-30dp"
        android:translationY="-50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/card2"
        android:layout_width="@dimen/card_width"
        android:layout_height="@dimen/card_height"
        android:src="@drawable/card_back"
        android:rotation="20"
        android:alpha="0.2"
        android:translationX="40dp"
        android:translationY="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/titleText" />

    <!-- Основной контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="@dimen/margin_medium"
            android:clipChildren="false"
            android:clipToPadding="false">

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.2" />

            <!-- Заголовок -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="@dimen/margin_large">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Игра в карточки 2"
                    style="@style/TitleStyle" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium Edition"
                    android:textSize="@dimen/subtitle_text_size"
                    android:fontFamily="@font/orbitron"
                    android:textColor="#80FFFFFF"
                    android:letterSpacing="0.2"
                    android:layout_marginTop="@dimen/margin_tiny" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.1" />

            <!-- Кнопки -->
            <androidx.cardview.widget.CardView
                android:id="@+id/playCard"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/margin_small"
                app:cardCornerRadius="@dimen/button_corner_radius"
                app:cardElevation="12dp"
                android:elevation="12dp"
                app:cardBackgroundColor="@android:color/transparent">

                <Button
                    android:id="@+id/playButton"
                    style="@style/CustomButton"
                    android:background="@drawable/button_3d_play"
                    android:foreground="@drawable/button_ripple_effect"
                    android:text="ИГРАТЬ"
                    android:drawableStart="@drawable/ic_play" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/inventoryCard"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/margin_small"
                app:cardCornerRadius="@dimen/button_corner_radius"
                app:cardElevation="12dp"
                android:elevation="12dp"
                app:cardBackgroundColor="@android:color/transparent">

                <Button
                    android:id="@+id/inventoryButton"
                    style="@style/CustomButton"
                    android:background="@drawable/button_3d_inventory"
                    android:foreground="@drawable/button_ripple_effect"
                    android:text="ИНВЕНТАРЬ"
                    android:drawableStart="@drawable/ic_inventory" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/shopCard"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/margin_small"
                app:cardCornerRadius="@dimen/button_corner_radius"
                app:cardElevation="12dp"
                android:elevation="12dp"
                app:cardBackgroundColor="@android:color/transparent">

                <Button
                    android:id="@+id/shopButton"
                    style="@style/CustomButton"
                    android:background="@drawable/button_3d_shop"
                    android:foreground="@drawable/button_ripple_effect"
                    android:text="МАГАЗИН"
                    android:drawableStart="@drawable/ic_shop" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/settingsCard"
                android:layout_width="@dimen/button_width"
                android:layout_height="@dimen/button_height"
                app:cardCornerRadius="@dimen/button_corner_radius"
                app:cardElevation="12dp"
                android:elevation="12dp"
                app:cardBackgroundColor="@android:color/transparent">

                <Button
                    android:id="@+id/settingsButton"
                    style="@style/CustomButton"
                    android:background="@drawable/button_3d_settings"
                    android:foreground="@drawable/button_ripple_effect"
                    android:text="НАСТРОЙКИ"
                    android:drawableStart="@drawable/ic_settings" />
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.3" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>