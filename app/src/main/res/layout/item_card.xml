<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Карточка -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardView"
        android:layout_width="140dp"
        android:layout_height="200dp"
        android:layout_margin="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardPreventCornerOverlap="true"
        app:cardUseCompatPadding="true"
        app:strokeWidth="2dp"
        app:strokeColor="#FFD700"
        android:stateListAnimator="@null"
        android:translationZ="4dp"
        android:elevation="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Фото -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cardImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/roundedImageView"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:importantForAccessibility="no" />

            <!-- Индикатор редкости -->
            <View
                android:id="@+id/rarityIndicator"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="#FFD700"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Значок редкости -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rarityBadge"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeWidth="2dp"
                app:strokeColor="#FFFFFF"
                app:cardBackgroundColor="#80000000"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/rarityIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/montserrat_bold" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Градиент -->
            <View
                android:id="@+id/gradientOverlay"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/gradient_overlay"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Имя -->
            <TextView
                android:id="@+id/cardName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:text="Имя"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat_bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#FF0000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Затемнение для недоступных карт -->
            <View
                android:id="@+id/lockOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#B3000000"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Замок -->
            <ImageView
                android:id="@+id/lockIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_lock"
                android:tint="#FFFFFF"
                android:visibility="gone"
                android:alpha="0.9"
                android:elevation="10dp"
                app:layout_constraintTop_toTopOf="@id/lockOverlay"
                app:layout_constraintBottom_toBottomOf="@id/lockOverlay"
                app:layout_constraintStart_toStartOf="@id/lockOverlay"
                app:layout_constraintEnd_toEndOf="@id/lockOverlay" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Чудик НАД картой -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimation"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-30dp"
        android:layout_marginEnd="-25dp"
        app:lottie_rawRes="@raw/chudik"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        android:visibility="gone"
        android:elevation="20dp"
        android:importantForAccessibility="no" />

</FrameLayout>