<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_settings_gradient"
    android:animateLayoutChanges="true">

    <!-- Эффект размытого стекла -->
    <View
        android:id="@+id/statusBarGradient"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_status_bar_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Декоративные квадратики -->
    <View
        android:id="@+id/decorSquare1"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_blur_square"
        android:alpha="0.08"
        android:translationX="-30dp"
        android:translationY="-20dp"
        android:rotation="15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/decorSquare2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_blur_square_purple"
        android:alpha="0.05"
        android:translationX="50dp"
        android:translationY="120dp"
        android:rotation="-10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Контейнер для анимации шаров -->
    <FrameLayout
        android:id="@+id/balloonContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Основной контент (вертикальный) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Верхняя панель -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/backButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentStart="true"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FFD700"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardBackgroundColor="#FF5722">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="←"
                        android:textSize="28sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:fontFamily="@font/montserrat_bold" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="НАСТРОЙКИ"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/playfair_display_bold"
                    android:letterSpacing="0.1"
                    android:shadowColor="#80000000"
                    android:shadowDx="2"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:layout_marginTop="8dp" />

            </RelativeLayout>

            <!-- Сегментированный контрол (горизонтальные табы) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#20FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabPromo"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Промокоды"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_tab_selected"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tabCredits"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Титры"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:textColor="#80FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_tab_default"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tabStats"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Статистика"
                        android:textSize="15sp"
                        android:textStyle="normal"
                        android:textColor="#80FFFFFF"
                        android:gravity="center"
                        android:background="@drawable/bg_tab_default"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Контейнер для промокодов -->
            <LinearLayout
                android:id="@+id/promoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#20FFFFFF"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Активация промокода"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Введите код для получения особой награды"
                            android:textSize="13sp"
                            android:textColor="#B3FFFFFF"
                            android:fontFamily="sans-serif"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundColor="#1AFFFFFF"
                            app:boxStrokeColor="#80FFFFFF"
                            app:boxStrokeWidth="1dp"
                            app:hintTextColor="#B3FFFFFF"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusBottomEnd="16dp"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/promoEditText"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:hint="Например: 31.03.2026"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#B3FFFFFF"
                                android:fontFamily="sans-serif"
                                android:textSize="15sp"
                                android:maxLines="1"
                                android:inputType="textNoSuggestions" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/activateButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Активировать"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            app:cornerRadius="24dp"
                            app:backgroundTint="#FF6B4A" />

                        <TextView
                            android:id="@+id/promoResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="13sp"
                            android:textColor="#FF6B4A"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:paddingTop="12dp"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Контейнер для списка промокодов -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#20FFFFFF">

                    <LinearLayout
                        android:id="@+id/promoListContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Доступные промокоды:"
                            android:textSize="12sp"
                            android:textColor="#80FFFFFF"
                            android:fontFamily="@font/montserrat_bold"
                            android:layout_marginBottom="12dp"
                            android:gravity="center" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Контейнер для титров - УБИРАЕМ nestedScrollingEnabled и добавляем высоту -->
            <LinearLayout
                android:id="@+id/creditsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#20FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="СОЗДАТЕЛИ"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/playfair_display_bold"
                            android:gravity="center"
                            android:layout_marginBottom="20dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/creditsRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="true" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Контейнер для статистики -->
            <LinearLayout
                android:id="@+id/statsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="СТАТИСТИКА"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/playfair_display_bold"
                            android:gravity="center"
                            android:layout_marginBottom="24dp" />

                        <RelativeLayout
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="16dp">

                            <View
                                android:id="@+id/winRateCircle"
                                android:layout_width="160dp"
                                android:layout_height="160dp"
                                android:layout_centerInParent="true"
                                android:background="@drawable/circle_progress_bg" />

                            <View
                                android:id="@+id/winsSector"
                                android:layout_width="160dp"
                                android:layout_height="160dp"
                                android:layout_centerInParent="true"
                                android:background="@drawable/circle_sector_green"
                                android:alpha="0.9" />

                            <View
                                android:id="@+id/defeatsSector"
                                android:layout_width="160dp"
                                android:layout_height="160dp"
                                android:layout_centerInParent="true"
                                android:background="@drawable/circle_sector_red"
                                android:alpha="0.9" />

                            <View
                                android:id="@+id/technicalSector"
                                android:layout_width="160dp"
                                android:layout_height="160dp"
                                android:layout_centerInParent="true"
                                android:background="@drawable/circle_sector_orange"
                                android:alpha="0.9" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/winRatePercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFD700"
                                    android:fontFamily="@font/montserrat_bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ПОБЕД"
                                    android:textSize="10sp"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/montserrat_regular" />

                            </LinearLayout>

                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginBottom="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Сыграно партий"
                                    android:textSize="12sp"
                                    android:textColor="#80FFFFFF"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/totalGamesText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFD700"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Поражения"
                                    android:textSize="12sp"
                                    android:textColor="#80FFFFFF"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/defeatsText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#E74C3C"
                                    android:fontFamily="@font/montserrat_bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="8dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Победы"
                                    android:textSize="12sp"
                                    android:textColor="#80FFFFFF"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/winsText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#2ECC71"
                                    android:fontFamily="@font/montserrat_bold"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Технические поражения"
                                    android:textSize="12sp"
                                    android:textColor="#80FFFFFF"
                                    android:fontFamily="@font/montserrat_regular"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/technicalDefeatsText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#F39C12"
                                    android:fontFamily="@font/montserrat_bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#80FFFFFF"
                            android:layout_marginVertical="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="8dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_deck"
                                android:tint="#FFD700"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Собрано карт"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/montserrat_bold" />

                            <TextView
                                android:id="@+id/cardsCollectedText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 / 0"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#FFD700"
                                android:fontFamily="@font/montserrat_bold" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/refreshButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_horizontal"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:strokeWidth="1dp"
                    app:strokeColor="#80FFFFFF"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    android:layout_marginTop="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_refresh"
                        android:tint="#FFFFFF"
                        android:layout_gravity="center" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>