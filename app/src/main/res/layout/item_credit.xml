<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/creditCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#20FFFFFF"
    app:strokeWidth="1dp"
    app:strokeColor="#40FFFFFF"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="false"
    android:focusable="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/creditIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_dev"
            android:tint="#FFD700"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/creditTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Разработчик"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/montserrat_bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/creditDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Имя"
                android:textSize="13sp"
                android:textColor="#CCCCCC"
                android:fontFamily="@font/montserrat_regular" />

        </LinearLayout>

        <!-- Стрелка для ссылок (видна только у кликабельных) -->
        <ImageView
            android:id="@+id/arrowIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_forward"
            android:tint="#80FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>