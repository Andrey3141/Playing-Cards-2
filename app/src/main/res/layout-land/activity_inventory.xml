<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:animateLayoutChanges="true">

    <!-- Декоративные карточки на фоне -->
    <ImageView
        android:id="@+id/decorCard1"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:src="@drawable/card_back"
        android:rotation="-10"
        android:alpha="0.15"
        android:translationX="-20dp"
        android:translationY="-20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/decorCard2"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:src="@drawable/card_back"
        android:rotation="15"
        android:alpha="0.15"
        android:translationX="20dp"
        android:translationY="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Стеклянная карточка -->
    <androidx.cardview.widget.CardView
        android:id="@+id/glassCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#B3FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Основной контент -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Верхняя панель с заголовком -->
        <RelativeLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Кнопка назад -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/backButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentStart="true"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:strokeWidth="2dp"
                app:strokeColor="#FFD700"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#FF5722">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="←"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="@font/montserrat_bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Заголовок по центру -->
            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="ИНВЕНТАРЬ"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/playfair_display_regular"
                android:letterSpacing="0.1"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:layout_marginTop="12dp" />

        </RelativeLayout>

        <!-- Табы под заголовком -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/tab_background"
            app:tabTextColor="#80FFFFFF"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabIndicatorColor="#FFD700"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextAppearance="@style/TabTextStyle"
            app:tabRippleColor="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Контентная область с вертикальным скроллом -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tabLayout"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="10"
                android:paddingBottom="16dp">

                <!-- Левая колонка: информация о категории -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/category_background"
                        android:padding="24dp">

                        <!-- Иконка категории -->
                        <ImageView
                            android:id="@+id/categoryIcon"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_deck"
                            android:tint="#FFD700"
                            android:layout_marginBottom="16dp" />

                        <!-- Название категории -->
                        <TextView
                            android:id="@+id/categoryTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Моя колода"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/playfair_display_regular"
                            android:gravity="center"
                            android:layout_marginBottom="8dp" />

                        <!-- Количество карт -->
                        <TextView
                            android:id="@+id/cardCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 карт"
                            android:textSize="16sp"
                            android:textColor="#80FFFFFF"
                            android:fontFamily="@font/montserrat_regular"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Правая колонка: карточки -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="7"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Доступные карты"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/montserrat_bold"
                        android:layout_marginBottom="12dp" />

                    <!-- RecyclerView для карточек (горизонтальный) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:clipToPadding="false"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>