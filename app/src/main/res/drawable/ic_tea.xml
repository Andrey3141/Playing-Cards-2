<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="40dp"
    android:height="40dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Два меча крест-накрест с красными кончиками -->

    <!-- Первый меч (слева направо) -->
    <group
        android:rotation="-30"
        android:pivotX="12"
        android:pivotY="9">
        <!-- Клинок -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M12,4 L10,12 L9.5,14 L14.5,14 L14,12 L12,4z"/>
        <!-- Красный кончик клинка -->
        <path
            android:fillColor="#0000FF"
            android:strokeColor="#000000"
            android:strokeWidth="0.4"
            android:pathData="M12,4 L11,7 L13,7 L12,4z"/>
        <!-- Крестовина -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M9.5,14 L14.5,14 L14.5,15 L9.5,15 L9.5,14z"/>
        <!-- Рукоять -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M11,15 L13,15 L13,19 L11,19 L11,15z"/>
        <!-- Навершие -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M10,19 L14,19 L14,20.5 L10,20.5 L10,19z"/>
    </group>

    <!-- Второй меч (справа налево) -->
    <group
        android:rotation="30"
        android:pivotX="12"
        android:pivotY="9">
        <!-- Клинок -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M12,4 L10,12 L9.5,14 L14.5,14 L14,12 L12,4z"/>
        <!-- Красный кончик клинка -->
        <path
            android:fillColor="#FF0000"
            android:strokeColor="#000000"
            android:strokeWidth="0.4"
            android:pathData="M12,4 L11,7 L13,7 L12,4z"/>
        <!-- Крестовина -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M9.5,14 L14.5,14 L14.5,15 L9.5,15 L9.5,14z"/>
        <!-- Рукоять -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M11,15 L13,15 L13,19 L11,19 L11,15z"/>
        <!-- Навершие -->
        <path
            android:fillColor="#FFFFFF"
            android:strokeColor="#000000"
            android:strokeWidth="0.5"
            android:pathData="M10,19 L14,19 L14,20.5 L10,20.5 L10,19z"/>
    </group>
