<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="4dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/button_corner_radius" />
            <solid android:color="#40000000" />
        </shape>
    </item>

    <item
        android:bottom="4dp"
        android:right="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/button_corner_radius" />
            <gradient
                android:startColor="@color/inventory_gradient_start"
                android:centerColor="@color/inventory_gradient_center"
                android:endColor="@color/inventory_gradient_end"
                android:angle="45"
                android:type="linear" />
            <stroke
                android:width="2dp"
                android:color="#80FFFFFF" />
        </shape>
    </item>
</layer-list>